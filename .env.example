# ============================================================
# COPAP BACKEND — ENVIRONMENT VARIABLES
# Used for production deployments (Railway, Render, VPS, etc.)
# For local dev, use application-local.yml instead.
# ============================================================

# ----- Database -----
DB_URL=jdbc:postgresql://<host>:5432/copap
DB_USER=copap_user
DB_PASSWORD=<strong-password>

# ----- Server -----
PORT=8080

# ----- CORS -----
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ----- Images -----
# Base URL used to build imageUrl in API responses
IMAGE_BASE_URL=https://your-backend.railway.app
# Directory where uploaded images are stored (use persistent volume on VPS)
# For S3/R2, this is replaced by bucket config (future migration)
UPLOAD_DIR=/data/uploads

# ----- Flyway -----
# Set to false for a fresh production database (no old tables exist)
# Set to true only when migrating from the old bare-JDK app
FLYWAY_BASELINE_ON_MIGRATE=false

# ----- Tuning (optional) -----
EXECUTOR_POOL_SIZE=3
ANALYTICS_WINDOW_MS=300000
